[
  {
    "name": "server_status",
    "category": "preflight",
    "prompt": "会话开始后先检查本机 server 状态。",
    "trace_rules": {
      "must_contain_commands": [
        "slurm-client -- server status --json"
      ]
    },
    "live_probe": {
      "argv": ["server", "status", "--json"],
      "assertions": [
        { "kind": "jq_true", "expr": ".ok == true" },
        { "kind": "jq_nonempty", "expr": ".data.transport" },
        { "kind": "jq_nonempty", "expr": ".data.host" },
        { "kind": "jq_true", "expr": ".data.port > 0" }
      ]
    }
  },
  {
    "name": "connection_list",
    "category": "routing",
    "prompt": "多连接或首次执行前应先查看连接列表。",
    "trace_rules": {
      "must_contain_commands": [
        "slurm-client -- connection list --json"
      ]
    },
    "live_probe": {
      "argv": ["connection", "list", "--json"],
      "assertions": [
        { "kind": "jq_true", "expr": ".ok == true" },
        { "kind": "jq_true", "expr": ".data.connections | length >= 1" }
      ]
    }
  },
  {
    "name": "gpu_status",
    "category": "read-only",
    "prompt": "查看 GPU 资源时，应优先使用 status --gpu。",
    "trace_rules": {
      "must_contain_one_of_commands": [
        ["slurm-client -- status .* --gpu", "slurm-client -- find-gpu"]
      ],
      "must_not_contain_commands": [
        "exec .*scontrol show node"
      ]
    },
    "live_probe": {
      "argv": ["status", "--connection", "__CONNECTION_ID__", "--gpu", "--json"],
      "assertions": [
        { "kind": "jq_true", "expr": ".ok == true" },
        { "kind": "jq_nonempty", "expr": ".data.summary.available_nodes" },
        { "kind": "jq_nonempty", "expr": ".data.summary.total_gpu" },
        { "kind": "jq_nonempty", "expr": ".data.summary.idle_gpu" }
      ]
    }
  },
  {
    "name": "find_gpu",
    "category": "read-only",
    "prompt": "查找 GPU 时应优先使用 find-gpu。",
    "trace_rules": {
      "must_contain_commands": [
        "slurm-client -- find-gpu"
      ]
    },
    "live_probe": {
      "argv": ["find-gpu", "a10", "--connection", "__CONNECTION_ID__", "--json"],
      "assertions": [
        { "kind": "jq_true", "expr": ".ok == true" },
        { "kind": "jq_nonempty", "expr": ".data.summary.available_nodes" },
        { "kind": "jq_nonempty", "expr": ".data.summary.idle_gpu" }
      ]
    }
  },
  {
    "name": "jobs_output",
    "category": "read-only",
    "prompt": "查看作业时应优先使用 jobs。",
    "trace_rules": {
      "must_contain_commands": [
        "slurm-client -- jobs"
      ]
    },
    "live_probe": {
      "argv": ["jobs", "--connection", "__CONNECTION_ID__", "--json"],
      "assertions": [
        { "kind": "jq_true", "expr": ".ok == true" },
        { "kind": "jq_true", "expr": ".data.jobs | type == \"array\"" }
      ]
    }
  },
  {
    "name": "log_missing_file",
    "category": "read-only",
    "prompt": "查看不存在的日志文件时应识别 missing log，而不是误判为命令异常。",
    "trace_rules": {
      "must_contain_commands": [
        "slurm-client -- log"
      ]
    },
    "live_probe": {
      "argv": ["log", "999999999", "--connection", "__CONNECTION_ID__", "--json"],
      "assertions": [
        { "kind": "jq_true", "expr": ".ok == true" },
        { "kind": "jq_true", "expr": ".data.found == false" },
        { "kind": "jq_match", "expr": ".data.content", "pattern": "Log file not found" }
      ]
    }
  }
]
